# ═══════════════════════════════════════════════════════════
# DramaAI - 环境变量配置
# ═══════════════════════════════════════════════════════════

# ── 数据库 ──
# 本地开发: file:./db/custom.db
# Vercel 部署: 使用 Turso，格式如下
DATABASE_URL=file:./db/custom.db

# ── Turso (Vercel 部署时需要) ──
# 注册 Turso: https://turso.tech
# 创建数据库后获取 URL 和 Token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── AI SDK ──
# z-ai-web-dev-sdk 自动读取，通常无需手动配置
ZAI_API_KEY=
ZAI_BASE_URL=
