# ═══════════════════════════════════════════════════════════
# DramaAI - 环境变量配置
# ═══════════════════════════════════════════════════════════

# ── 数据库 (本地开发) ──
DATABASE_URL=file:./db/custom.db

# ── 数据库 (Vercel 部署 - 必填!) ──
# Vercel 不支持 SQLite 文件数据库，需要使用 Turso (libSQL)
# 
# 快速开始:
#   1. 安装 Turso CLI:  curl -sSfL https://get.tur.so/install.sh | bash
#   2. 注册账号:        turso auth signup
#   3. 创建数据库:      turso db create drama-ai
#   4. 获取连接URL:     turso db show drama-ai --url
#   5. 生成认证Token:   turso db tokens create drama-ai
#   6. 推送表结构:      TURSO_DATABASE_URL="libsql://..." TURSO_AUTH_TOKEN="..." npx prisma db push
#
# 然后在 Vercel 项目 Settings → Environment Variables 中添加:
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# ── AI SDK ──
# z-ai-web-dev-sdk 自动读取，通常无需手动配置
ZAI_API_KEY=
ZAI_BASE_URL=
