# ═══════════════════════════════════════════════════════════
# DramaAI - 环境变量配置
# ═══════════════════════════════════════════════════════════

# ── 数据库 (本地开发 - SQLite) ──
DATABASE_URL=file:./db/custom.db
DIRECT_URL=file:./db/custom.db

# ── 数据库 (Vercel 部署 - PostgreSQL) ──
# Vercel Postgres 会自动配置以下变量:
# DATABASE_URL=postgresql://... (连接池 URL)
# DIRECT_URL=postgresql://... (直连 URL)

# ── AI SDK ──
# z-ai-web-dev-sdk 自动读取，通常无需手动配置
ZAI_API_KEY=
ZAI_BASE_URL=
